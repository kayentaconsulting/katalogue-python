{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(uv sync:*)",
      "Bash(uv run:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run pytest --tb=short -q"
          }
        ]
      }
    ]
  }
}
