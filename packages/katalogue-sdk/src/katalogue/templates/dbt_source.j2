{% set _groups = dataset_groups if (dataset_groups is defined and dataset_groups) else ([dataset_group] if (dataset_group is defined and dataset_group) else []) %}
version: 2
sources:
{% for dg in _groups %}
{% set dg_datasource = datasource if datasource is defined and datasource else (datasources | selectattr('datasource_id', 'equalto', dg.datasource_id) | list | first | default({})) %}
{% set dg_datasets = datasets | selectattr('dataset_group_id', 'equalto', dg.dataset_group_id) | list %}
  - name: {{ dg.dataset_group_name }}
    database: {{ dg_datasource.datasource_name | default('', true) }}
    schema: {{ dg.dataset_group_name }}
    tables:
{% for ds in dg_datasets %}
      - name: {{ ds.dataset_name }}
        description: {{ dataset_desc(ds) | yaml_str }}
        columns:
{% for f in fields_tree(ds.dataset_id) recursive %}
          - name: {{ f.field_path }}
            data_type: {{ field_type(f) }}
            description: {{ field_desc(f) | yaml_str }}
{% if field_is_primary_key(f) or field_is_pii(f) %}
            config:
              meta:
{% if field_is_primary_key(f) %}
                is_primary_key: true
{% endif %}
{% if field_is_pii(f) %}
                is_pii: true
{% endif %}
{% endif %}
{{ loop(f.children) }}
{%- endfor %}
{% endfor %}
{% endfor %}
